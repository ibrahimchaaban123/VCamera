<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VCamera"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Virtual Camera for Android 16"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <!-- Service Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvServiceStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴 Stopped"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnToggleService"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Start Virtual Camera"
                    android:textSize="16sp"
                    android:backgroundTint="@color/green_accent"
                    android:textColor="@color/white" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Controls (visible when service running) -->
        <LinearLayout
            android:id="@+id/layoutControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Source Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📁 Source"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvCurrentSource"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No source selected"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvSourceStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○ Inactive"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Source Buttons Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnPickImage"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="🖼 Image"
                            android:textSize="12sp"
                            android:backgroundTint="@color/blue_accent"
                            android:layout_marginEnd="6dp" />

                        <Button
                            android:id="@+id/btnPickVideo"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="🎬 Video"
                            android:textSize="12sp"
                            android:backgroundTint="@color/purple_accent"
                            android:layout_marginEnd="6dp" />

                        <Button
                            android:id="@+id/btnNetworkStream"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="🌐 Stream"
                            android:textSize="12sp"
                            android:backgroundTint="@color/orange_accent"
                            android:layout_marginEnd="6dp" />

                        <Button
                            android:id="@+id/btnClearSource"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="✕ Clear"
                            android:textSize="12sp"
                            android:backgroundTint="@color/red_accent" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Transform Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔧 Transform"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Zoom Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Zoom"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:minWidth="52dp" />

                        <Button
                            android:id="@+id/btnZoomOut"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="−"
                            android:textSize="20sp"
                            android:backgroundTint="@color/control_bg"
                            android:padding="0dp" />

                        <SeekBar
                            android:id="@+id/seekbarZoom"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="8dp" />

                        <Button
                            android:id="@+id/btnZoomIn"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="+"
                            android:textSize="20sp"
                            android:backgroundTint="@color/control_bg"
                            android:padding="0dp" />

                        <TextView
                            android:id="@+id/tvZoomLevel"
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:text="1.0x"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Rotate Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <Button
                            android:id="@+id/btnRotateLeft"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="↺ -90°"
                            android:textSize="13sp"
                            android:backgroundTint="@color/control_bg"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnRotateRight"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="↻ +90°"
                            android:textSize="13sp"
                            android:backgroundTint="@color/control_bg" />
                    </LinearLayout>

                    <!-- Flip Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <Button
                            android:id="@+id/btnFlipH"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="⇔ Flip H"
                            android:textSize="13sp"
                            android:backgroundTint="@color/control_bg"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnFlipV"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="⇕ Flip V"
                            android:textSize="13sp"
                            android:backgroundTint="@color/control_bg" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnResetTransform"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Reset All"
                        android:textSize="14sp"
                        android:backgroundTint="@color/control_bg" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
